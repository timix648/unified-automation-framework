# =============================================================================
# UAF Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables have sensible defaults for mock/dev mode.
# =============================================================================

# --- System ---
PROJECT_NAME=UAF - Unified Automation Framework
VERSION=1.0.0
MOCK_MODE=True

# --- Cisco Credentials (SSH/Netmiko) ---
CISCO_IP=192.168.1.10
CISCO_USER=admin
CISCO_PASS=cisco123
CISCO_SECRET=cisco123
CISCO_PORT=22

# --- MikroTik Credentials (RouterOS API) ---
MIKROTIK_IP=192.168.1.20
MIKROTIK_USER=admin
MIKROTIK_PASS=mikrotik123
MIKROTIK_PORT=22

# --- UniFi Controller (REST API) ---
UNIFI_IP=192.168.1.30
UNIFI_USER=ubnt
UNIFI_PASS=ubnt123
UNIFI_PORT=8443
UNIFI_SITE=default

# --- NetBox (Source of Truth) ---
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=

# --- MQTT (WoL Bridge Agent) ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=uaf/wol/commands

# --- JWT Authentication ---
# IMPORTANT: Set a strong, unique secret key in production!
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_EXPIRE_MINUTES=480

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
