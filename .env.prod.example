# ===========================================================================
# UAF Production Environment (.env.prod)
# Copy to ".env.prod" and fill in. Referenced by docker-compose.prod.yml.
# Never commit the real file — it holds device credentials and the JWT secret.
# ===========================================================================

# --- Core ---
MOCK_MODE=False
PROJECT_NAME=UAF - Unified Automation Framework
VERSION=1.0.0

# --- JWT (MUST be set so sessions survive restarts) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=60

# --- Seeded account passwords (override the demo defaults) ---
# These set the initial admin/operator/viewer passwords at deploy time so they
# are NOT hardcoded in the source. Users can also change their own password
# in-app (Settings -> Account Security); role is always preserved.
ADMIN_PASSWORD=change-this-admin-password
OPERATOR_PASSWORD=change-this-operator-password
VIEWER_PASSWORD=change-this-viewer-password

# --- Tailscale mesh (Report 4.3) ---
# Reusable or ephemeral auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
# How the frontend container reaches the backend API + WebSocket. The backend
# shares the tailscale sidecar's network namespace, so from the frontend
# container the backend is reachable at the tailscale service name:
PUBLIC_API_BASE=http://tailscale:8000/api

# --- Device inventory (NetBox SSoT) — optional ---
# Point at an existing NetBox, or leave blank to use the built-in inventory.
NETBOX_URL=
NETBOX_TOKEN=

# --- Device addresses (as reachable OVER the tailnet from the cloud) ---
CISCO_IP=192.168.1.10
CISCO_USER=admin
CISCO_PASS=
CISCO_SECRET=
CISCO_PORT=22

MIKROTIK_IP=192.168.1.20
MIKROTIK_USER=admin
MIKROTIK_PASS=
MIKROTIK_PORT=8728

UNIFI_IP=192.168.1.30
UNIFI_USER=admin
UNIFI_PASS=
UNIFI_PORT=8443
UNIFI_SITE=default

# --- WoL bridge MQTT (optional) ---
MQTT_BROKER=localhost
MQTT_PORT=1883